# ClauseLens server-side configuration.
#
# These are SERVER environment variables, read only by the Netlify Function.
# They are never exposed to the browser. Do NOT use a VITE_ prefix here, and
# never put the API key in client code or the bundle.
#
# For local dev:  copy this file to .env and run `netlify dev`.
# For production: set these in the Netlify dashboard (Site settings > Env vars).

# Your Anthropic API key. Server side only.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# The model id the function should call, for example claude-haiku-4-5-20251001.
# Required: there is no hardcoded default, so a missing value fails in config.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Optional. Comma separated list of extra browser origins allowed to call the
# function. Same-origin and localhost are always allowed, so you usually only
# need this if the app is served from a different domain than the function.
# ALLOWED_ORIGIN=https://clauselens.netlify.app
